namespace App\Http\Controllers;

use App\Models\Startup;
use App\Models\Sector;
use App\Models\State;

class StartupController extends Controller
{
    public function index(Request $request)
    {
        // Load filter options from DB (no hardcoding)
        $sectors = Sector::orderBy('sector_name')->get(['id','sector_name']);
        $states  = State::orderBy('state_name')->get(['id','state_name']);

        $fundingStages = Startup::select('funding_stage')
            ->distinct()
            ->orderBy('funding_stage')
            ->pluck('funding_stage');

        $statuses = Startup::select('status')
            ->distinct()
            ->orderBy('status')
            ->pluck('status');

        // Collect all active filters from request
        $filters = $request->only([
            'search','sector_id','state_id',
            'funding_stage','status','dpiit_recognized',
            'women_led','ai_enabled',
            'year_from','year_to',
            'funding_min','funding_max',
        ]);

        $sort    = $request->get('sort', 'newest');
        $perPage = $request->get('per_page', 25);

        // Validate per_page
        $perPage = in_array($perPage,[10,25,50,100])
            ? $perPage : 25;

        // Main query
        $startups = Startup::with(['sector','state','tags'])
            ->filter($filters)
            ->sorted($sort)
            ->paginate($perPage)
            ->withQueryString();

        // Summary counts (filtered)
        $filteredTotal   = Startup::filter($filters)->count();
        $activeCount     = Startup::filter($filters)
                            ->where('status','Active')->count();
        $dpiitCount      = Startup::filter($filters)
                            ->where('dpiit_recognized',true)->count();
        $womenLedCount   = Startup::filter($filters)
                            ->where('women_led',true)->count();

        // Check if any filter is active (for chip display)
        $hasActiveFilters = collect($filters)
            ->filter(fn($v) => !is_null($v) && $v !== '')
            ->isNotEmpty();

        return view('startups.index', compact(
            'startups','sectors','states',
            'fundingStages','statuses',
            'filters','sort','perPage',
            'filteredTotal','activeCount',
            'dpiitCount','womenLedCount',
            'hasActiveFilters'
        ));
    }

    public function destroy(Startup $startup)
    {
        $startup->delete();
        return redirect()->route('startups.index')
            ->with('success', 'Startup deleted successfully.');
    }

    public function bulkDestroy(Request $request)
    {
        $ids = $request->input('ids',[]);
        Startup::whereIn('id', $ids)->delete();
        return response()->json([
            'message' => count($ids).' startups deleted.'
        ]);
    }

    public function export(Request $request)
    {
        $filters = $request->only([
            'search','sector_id','state_id',
            'funding_stage','status','dpiit_recognized',
            'women_led','ai_enabled',
            'year_from','year_to',
            'funding_min','funding_max',
        ]);

        $sort = $request->get('sort','newest');

        $startups = Startup::with(['sector','state','tags'])
            ->filter($filters)
            ->sorted($sort)
            ->get();

        $filename = 'startups_export_'.now()->format('Ymd_His').'.csv';

        $headers = [
            'Content-Type'        => 'text/csv',
            'Content-Disposition' => "attachment; filename={$filename}",
        ];

        $columns = [
            'ID','Name','Sector','State','City',
            'Funding Stage','Status','DPIIT',
            'Founded Year','Total Funding (USD)',
            'Valuation (USD)','Revenue (INR)',
            'Employees','Growth %','Women Led',
            'AI Enabled','Jobs Created','Patents Filed',
            'Registration No','Website','Email',
            'Last Funding Date','Tags'
        ];

        $callback = function() use ($startups, $columns) {
            $file = fopen('php://output','w');
            fputcsv($file, $columns);
            foreach($startups as $s) {
                fputcsv($file, [
                    $s->id,
                    $s->startup_name,
                    $s->sector->sector_name ?? '',
                    $s->state->state_name ?? '',
                    $s->city,
                    $s->funding_stage,
                    $s->status,
                    $s->dpiit_recognized ? 'Yes' : 'No',
                    $s->founded_year,
                    $s->total_funding_usd,
                    $s->valuation_usd,
                    $s->annual_revenue_inr,
                    $s->employee_count,
                    $s->growth_percentage,
                    $s->women_led ? 'Yes' : 'No',
                    $s->ai_enabled ? 'Yes' : 'No',
                    $s->jobs_created,
                    $s->patents_filed,
                    $s->registration_number,
                    $s->website,
                    $s->email,
                    $s->last_funding_date?->format('d M Y'),
                    $s->tags->pluck('tag')->implode(', '),
                ]);
            }
            fclose($file);
        };

        return response()->stream($callback, 200, $headers);
    }

    public function bulkExport(Request $request)
    {
        $ids = $request->input('ids', []);
        $startups = Startup::with(['sector','state','tags'])
            ->whereIn('id', $ids)
            ->get();

        // Same CSV stream logic as export()
        // Reuse the same callback pattern above
        // filename: startups_selected_export_{timestamp}.csv
    }

    public function bulkStatusUpdate(Request $request)
    {
        $ids    = $request->input('ids', []);
        $status = $request->input('status');

        $allowed = ['Active','Inactive','Acquired','Failed'];
        if(!in_array($status, $allowed)) {
            return response()->json(['error'=>'Invalid status'],422);
        }

        Startup::whereIn('id', $ids)
            ->update(['status' => $status]);

        return response()->json([
            'message' => count($ids).' startups updated to '.$status
        ]);
    }
}

