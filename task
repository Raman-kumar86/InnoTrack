namespace App\Models;

class Startup extends Model
{
    protected $fillable = [
        'startup_name','slug','dpiit_recognized',
        'registration_number','founded_year','founder_count',
        'sector_id','state_id','city','funding_stage',
        'total_funding_usd','valuation_usd',
        'annual_revenue_inr','employee_count','women_led',
        'sustainability_focus','ai_enabled','export_business',
        'website','email','phone','linkedin_url','status',
        'last_funding_date','growth_percentage','jobs_created',
        'patents_filed','description'
    ];

    protected $casts = [
        'dpiit_recognized'    => 'boolean',
        'women_led'           => 'boolean',
        'ai_enabled'          => 'boolean',
        'sustainability_focus'=> 'boolean',
        'export_business'     => 'boolean',
        'growth_percentage'   => 'float',
        'last_funding_date'   => 'date',
    ];

    public function sector()
    {
        return $this->belongsTo(Sector::class);
    }

    public function state()
    {
        return $this->belongsTo(State::class);
    }

    public function founders()
    {
        return $this->hasMany(Founder::class);
    }

    public function fundingRounds()
    {
        return $this->hasMany(FundingRound::class);
    }

    public function documents()
    {
        return $this->hasMany(StartupDocument::class);
    }

    public function tags()
    {
        return $this->hasMany(StartupTag::class);
    }

    public function updates()
    {
        return $this->hasMany(StartupUpdate::class);
    }

    public function scopeFilter($query, array $filters)
    {
        $query
            ->when($filters['search'] ?? null, function($q, $search) {
                $q->where(function($q) use ($search) {
                    $q->where('startup_name','like',"%{$search}%")
                      ->orWhere('registration_number','like',"%{$search}%")
                      ->orWhere('city','like',"%{$search}%")
                      ->orWhereHas('sector', fn($q) =>
                            $q->where('sector_name','like',"%{$search}%"))
                      ->orWhereHas('founders', fn($q) =>
                            $q->where('full_name','like',"%{$search}%"));
                });
            })
            ->when($filters['sector_id'] ?? null, fn($q,$v) =>
                $q->where('sector_id',$v))
            ->when($filters['state_id'] ?? null, fn($q,$v) =>
                $q->where('state_id',$v))
            ->when($filters['funding_stage'] ?? null, fn($q,$v) =>
                $q->whereIn('funding_stage', (array)$v))
            ->when($filters['status'] ?? null, fn($q,$v) =>
                $q->where('status',$v))
            ->when($filters['dpiit_recognized'] ?? null, fn($q,$v) =>
                $q->where('dpiit_recognized', $v === 'Yes'))
            ->when($filters['women_led'] ?? null, fn($q,$v) =>
                $q->where('women_led', true))
            ->when($filters['ai_enabled'] ?? null, fn($q,$v) =>
                $q->where('ai_enabled', true))
            ->when($filters['year_from'] ?? null, fn($q,$v) =>
                $q->where('founded_year','>=',$v))
            ->when($filters['year_to'] ?? null, fn($q,$v) =>
                $q->where('founded_year','<=',$v))
            ->when($filters['funding_min'] ?? null, fn($q,$v) =>
                $q->where('total_funding_usd','>=',$v))
            ->when($filters['funding_max'] ?? null, fn($q,$v) =>
                $q->where('total_funding_usd','<=',$v));
    }

    public function scopeSorted($query, $sort)
    {
        return match($sort) {
            'name_asc'      => $query->orderBy('startup_name','asc'),
            'name_desc'     => $query->orderBy('startup_name','desc'),
            'founded_new'   => $query->orderBy('founded_year','desc'),
            'founded_old'   => $query->orderBy('founded_year','asc'),
            'funding_high'  => $query->orderBy('total_funding_usd','desc'),
            'funding_low'   => $query->orderBy('total_funding_usd','asc'),
            'growth_high'   => $query->orderBy('growth_percentage','desc'),
            'growth_low'    => $query->orderBy('growth_percentage','asc'),
            'employees_high'=> $query->orderBy('employee_count','desc'),
            'valuation_high'=> $query->orderBy('valuation_usd','desc'),
            default         => $query->orderBy('created_at','desc'),
        };
    }
}

